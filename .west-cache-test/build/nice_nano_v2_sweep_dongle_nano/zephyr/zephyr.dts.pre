/ {

    chosen {
        zmk,kscan = &kscan0;
        zmk,matrix-transform = &default_transform;
    };

    default_transform: keymap_transform_0 {
        compatible = "zmk,matrix-transform";
        columns = <34>;
        rows = <1>;
        map = <
        (((0) << 8) + (0)) (((0) << 8) + (1)) (((0) << 8) + (2)) (((0) << 8) + (3)) (((0) << 8) + (4)) (((0) << 8) + (21)) (((0) << 8) + (20)) (((0) << 8) + (19)) (((0) << 8) + (18)) (((0) << 8) + (17))
        (((0) << 8) + (5)) (((0) << 8) + (6)) (((0) << 8) + (7)) (((0) << 8) + (8)) (((0) << 8) + (9)) (((0) << 8) + (26)) (((0) << 8) + (25)) (((0) << 8) + (24)) (((0) << 8) + (23)) (((0) << 8) + (22))
        (((0) << 8) + (10)) (((0) << 8) + (11)) (((0) << 8) + (12)) (((0) << 8) + (13)) (((0) << 8) + (14)) (((0) << 8) + (31)) (((0) << 8) + (30)) (((0) << 8) + (29)) (((0) << 8) + (28)) (((0) << 8) + (27))
                                   (((0) << 8) + (15)) (((0) << 8) + (16)) (((0) << 8) + (33)) (((0) << 8) + (32))
        >;
    };

    kscan0: kscan {
        compatible = "zmk,kscan-gpio-direct";
        wakeup-source;

        input-gpios
        = <&pro_micro 4 ((0 << 0) | (1 << 5))>
        , <&pro_micro 5 ((0 << 0) | (1 << 5))>
        , <&pro_micro 6 ((0 << 0) | (1 << 5))>
        , <&pro_micro 7 ((0 << 0) | (1 << 5))>
        ;
    };

};
